programa {
  funcao inicio() {
    // 1. Preparação (suas variáveis do tipo real)
    real precoCompra, precoVenda

    // 2. Entrada (conversando com o Seu Romero)
    escreva("Digite o preço de compra: ")
    leia(precoCompra)

    // 3. Processamento (a sua matemática pelo caminho direto!)
    precoVenda = precoCompra * 3

    // 4. Saída (entregando o resultado)
    escreva("Preço de venda: R$" + precoVenda)
  }
}
